# ============================================================
# AI 智能投标系统 · 本地开发环境变量模板
# 复制为 .env 后按需修改，.env 已加入 .gitignore（禁止提交）
# ============================================================

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------
POSTGRES_USER=bidai
POSTGRES_PASSWORD=bidai_dev_pass
POSTGRES_DB=bidai
POSTGRES_PORT=5432

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_PASSWORD=bidai_redis_pass
REDIS_PORT=6379

# ----------------------------------------------------------
# Elasticsearch
# ----------------------------------------------------------
ES_PORT=9200

# ----------------------------------------------------------
# MinIO（项目对象存储）
# ----------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----------------------------------------------------------
# Milvus
# ----------------------------------------------------------
MILVUS_PORT=19530

# ----------------------------------------------------------
# 应用服务环境变量（供各微服务参考）
# ----------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://bidai:bidai_dev_pass@localhost:5432/bidai
REDIS_URL=redis://:bidai_redis_pass@localhost:6379/0
MILVUS_HOST=localhost
MILVUS_PORT=19530
ES_URL=http://localhost:9200
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# LLM（本地开发如未部署 GPU 节点，可留空或填外部 API）
LLM_PRIVATE_BASE_URL=
LLM_PRIVATE_MODEL=
LLM_PRIVATE_TIMEOUT=120

# 安全（本地开发使用占位值，生产通过 K8s Secret 注入）
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# 应用
APP_ENV=development
LOG_LEVEL=INFO
